    {
      "id": 51,
      "type": "timeseries",
      "title": "Upstream P95 Latency",
      "description": "Backend service health over time for this API.",
      "datasource": { "uid": "${datasource_prometheus}", "type": "prometheus" },
      "gridPos": { "x": 0, "y": 61, "w": 8, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by(le)(rate(tyk_upstream_request_duration_seconds_bucket{service_name=\"tyk-gateway\", tyk_api_id=\"$api_id\", tyk_gw_id=~\"$tyk_gw_id\"}[$__rate_interval]))) * 1000", "legendFormat": "Upstream P95" },
        { "refId": "B", "expr": "histogram_quantile(0.50, sum by(le)(rate(tyk_upstream_request_duration_seconds_bucket{service_name=\"tyk-gateway\", tyk_api_id=\"$api_id\", tyk_gw_id=~\"$tyk_gw_id\"}[$__rate_interval]))) * 1000", "legendFormat": "Upstream P50" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
