      "gridPos": { "x": 16, "y": 46, "w": 8, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "sum by(http_request_method)(rate(tyk_api_requests_total{service_name=\"tyk-gateway\", tyk_api_id=\"$api_id\", tyk_gw_id=~\"$tyk_gw_id\"}[$__rate_interval]))", "legendFormat": "{{http_request_method}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 44,
