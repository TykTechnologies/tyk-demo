      "gridPos": { "x": 8, "y": 61, "w": 8, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"tyk-gateway\", tyk_api_id=\"$api_id\", tyk_response_flag=\"URS\", tyk_gw_id=~\"$tyk_gw_id\"}[$__rate_interval]))", "legendFormat": "URS (upstream 5xx) rate" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "color": { "mode": "fixed", "fixedColor": "red" } } },
